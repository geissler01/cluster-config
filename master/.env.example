# ==============================================================================
# VARIABLES GLOBALES DEL CLÚSTER DE DATOS - AIRFLOW 3.2.0
# ==============================================================================

# El usuario interno de Linux que usará Airflow (50000 es el estándar de la imagen oficial)
AIRFLOW_UID=50000

# Le decimos a Python dónde buscar módulos custom. Apunta a la carpeta donde clonarás tus DAGs
PYTHONPATH=/opt/airflow/dags

# Dependencias extra que el Dockerfile instalará al hacer el 'build'. 
# Incluye AWS para logs, psycopg2 para Postgres, celery para workers y gunicorn para la web.
EXTRA_REQUIREMENTS=apache-airflow-providers-amazon apache-airflow-providers-celery psycopg2-binary celery gunicorn

# ==============================================================================
# BASE DE DATOS EXTERNA (Postgres por IP Privada)
# ==============================================================================
# Cadena de conexión usando la IP PRIVADA de tu base de datos (Ej: 10.0.1.50)
# Formato: postgresql+psycopg2://usuario:password@IP_PRIVADA:5432/nombre_db
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://usuario:password@10.0.0.1:5432/airflow_db

# ==============================================================================
# CELERY Y RABBITMQ (Orquestación Distribuida)
# ==============================================================================
# Executor para clústeres de múltiples nodos
AIRFLOW__CORE__EXECUTOR=CeleryExecutor

# URL del broker usando la IP PRIVADA de la instancia RabbitMQ (Ej: 10.0.2.17)
# Formato: amqp://usuario:password@IP_PRIVADA:5672//
AIRFLOW__CELERY__BROKER_URL=amqp://usuario:password@10.0.0.2:5672//

# Backend donde los workers guardan el resultado de sus tareas (generalmente la misma DB principal)
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://usuario:password@10.0.0.1:5432/airflow_db

# ==============================================================================
# SEGURIDAD CRÍTICA (Generar llaves en la terminal)
# ==============================================================================
# Llave para encriptar contraseñas en la base de datos (Conexiones, Variables).
# COMANDO PARA GENERARLA: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=tu_fernet_key_generada_aqui

# Llave secreta para las sesiones de la interfaz web (Flask).
# COMANDO PARA GENERARLA: openssl rand -hex 32
AIRFLOW__API__SECRET_KEY=tu_secret_key_generada_aqui

# En Airflow 3, la API usa JWT para validar que los Workers son legítimos.
# COMANDO PARA GENERARLA: openssl rand -hex 32
AIRFLOW__API_AUTH__JWT_SECRET=tu_jwt_secret_generada_aqui

# El emisor del token (La URL de tu dominio o proxy web)
AIRFLOW__API_AUTH__JWT_ISSUER=http://tu-dominio.com/execution/

# ==============================================================================
# CONFIGURACIÓN WEB / API (Airflow 3)
# ==============================================================================
# URL base donde se accede a la interfaz de Airflow
AIRFLOW__API__BASE_URL=http://tu-dominio.com

# Nombre amigable que aparecerá en la interfaz
AIRFLOW__API__INSTANCE_NAME="Nombre de tu Clúster"

# Ruta interna del contenedor donde se montará el volumen de DAGs
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags

# Configuración por defecto para nuevos DAGs
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true

# Desactivar ejemplos de Airflow para mantener la interfaz limpia
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Gestor de autenticación (Requisito de Airflow 3+)
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager

# Credenciales iniciales para el primer despliegue
_AIRFLOW_DB_MIGRATE=true
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=tu_password_admin_airflow

# ==============================================================================
# LOGS EN LA NUBE (AWS S3)
# ==============================================================================
# Activar el almacenamiento remoto de logs
AIRFLOW__LOGGING__REMOTE_LOGGING=true

# Ruta del bucket S3 donde se guardarán los logs (Ej: s3://nombre-bucket/logs)
AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=s3://tu-bucket-s3/logs

# ID de la conexión de Airflow que tiene las credenciales de AWS
AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=my_s3_conn

# Encriptación de logs en S3
AIRFLOW__LOGGING__ENCRYPT_S3_LOGS=false
